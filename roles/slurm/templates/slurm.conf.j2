ClusterName=cluster
{% for controller in groups['slurm_controller'] %}
SlurmctldHost={{ hostvars[controller]['ansible_hostname'] }}
{% endfor %}
ReturnToService=1
SlurmctldPidFile=/var/run/slurmctld.pid
SlurmctldPort=6817
SlurmdPidFile=/var/run/slurmd.pid
SlurmdPort=6818
SrunPortRange={{ slurm_srun_ports["start"] }}-{{ slurm_srun_ports["end"] }}
SlurmdSpoolDir=/var/spool/slurmd
SlurmUser=slurm
StateSaveLocation=/var/spool/slurmctld
TaskPlugin=task/affinity,task/cgroup
# TIMERS
InactiveLimit=0
KillWait=30
MinJobAge=300
SlurmctldTimeout=120
SlurmdTimeout=300
Waittime=0
#
#
# SCHEDULING
SchedulerType=sched/backfill
SelectType=select/cons_tres
#
#
# LOGGING AND ACCOUNTING
JobCompType=jobcomp/none
JobAcctGatherFrequency=30
SlurmctldDebug=info
SlurmctldLogFile=/var/log/slurm/slurmctld.log
SlurmdDebug=info
SlurmdLogFile=/var/log/slurm/slurmd.log
#SlurmSchedLogLevel=
#
#
# COMPUTE NODES
{% for compute in groups['slurm_compute'] %}
{% if 'slurm_hardware' in hostvars[compute] %}
{{ hostvars[compute]['slurm_hardware'] }}
{% else %}
# WARNING: slurm_hardware missing for {{ compute }}
{% endif %}
{% endfor %}
PartitionName=debug Nodes=ALL Default=YES MaxTime=INFINITE State=UP
